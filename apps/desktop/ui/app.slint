import { StatusBar, Sidebar, EditorPanel, ResultsPanel, CommandPalette, ResultRowData } from "components.slint";

export global AppState {
    in-out property <bool> sidebar-visible: false;
    in-out property <bool> results-visible: false;
    in-out property <bool> command-palette-open: false;
    in-out property <string> active-connection: "";
    in-out property <string> connection-status: "● Disconnected";
    in-out property <string> status-text: "Ready";
    callback open-command-palette();
    callback close-command-palette();
    callback new-query();
    callback connect();
    callback disconnect();
    callback toggle-sidebar();
    callback toggle-results();
    callback execute-command(string);
    callback execute-query(string);
    in-out property <string> current-sql: "SELECT @@VERSION";
    in-out property <[string]> result-columns;
    in-out property <[ResultRowData]> result-rows;
    in-out property <string> result-text: "";
}

export component MainWindow inherits Window {
    title: "GetAGrip";
    preferred-width: 1400px;
    preferred-height: 900px;
    min-width: 800px;
    min-height: 500px;
    background: #1e1e2e;

    VerticalLayout {
        // Menu bar
        Rectangle {
            height: 32px; background: #181825;
            HorizontalLayout {
                padding-left: 8px; padding-right: 8px; spacing: 2px;

                Text { text: "GetAGrip"; font-weight: 700; font-size: 13px; color: #cdd6f4; vertical-alignment: center; }
                Rectangle { width: 16px; }

                Rectangle {
                    border-radius: 4px; background: #181825;
                    HorizontalLayout {
                        padding-left: 10px; padding-right: 10px; padding-top: 4px; padding-bottom: 4px;
                        Text {
                            text: AppState.active-connection == "" ? "● Not Connected" : "● " + AppState.active-connection;
                            font-size: 12px; vertical-alignment: center;
                            color: AppState.active-connection == "" ? #6c7086 : #a6e3a1;
                        }
                    }
                    TouchArea { clicked => { AppState.connect(); } }
                }

                Rectangle {
                    border-radius: 4px;
                    background: AppState.active-connection == "" ? #45475a : #a6e3a1;
                    HorizontalLayout {
                        padding-left: 14px; padding-right: 14px; padding-top: 4px; padding-bottom: 4px;
                        Text {
                            text: AppState.active-connection == "" ? "▶ Not Connected" : "▶ Run (Ctrl+Enter)";
                            font-size: 12px; font-weight: 600;
                            color: AppState.active-connection == "" ? #6c7086 : #1e1e2e;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea {
                        clicked => {
                            if AppState.active-connection != "" {
                                AppState.execute-query(AppState.current-sql);
                            }
                        }
                    }
                }

                Rectangle { width: 8px; }

                Rectangle {
                    border-radius: 4px; background: #181825;
                    HorizontalLayout {
                        padding-left: 10px; padding-right: 10px; padding-top: 4px; padding-bottom: 4px;
                        Text { text: "+ Query"; font-size: 12px; color: #cdd6f4; vertical-alignment: center; }
                    }
                    TouchArea { clicked => { AppState.new-query(); } }
                }

                Rectangle {
                    border-radius: 4px; background: #181825;
                    HorizontalLayout {
                        padding-left: 10px; padding-right: 10px; padding-top: 4px; padding-bottom: 4px;
                        Text { text: "☰"; font-size: 14px; color: #cdd6f4; vertical-alignment: center; }
                    }
                    TouchArea { clicked => { AppState.toggle-sidebar(); } }
                }

                Rectangle { width: 1px; background: #45475a; }

                Rectangle {
                    border-radius: 4px; background: #181825;
                    HorizontalLayout {
                        padding-left: 14px; padding-right: 14px; padding-top: 4px; padding-bottom: 4px;
                        Text { text: "Ctrl+P  Search..."; font-size: 11px; color: #6c7086; vertical-alignment: center; }
                    }
                    TouchArea { clicked => { AppState.open-command-palette(); } }
                }
            }
        }

        // Main content
        HorizontalLayout {
            if AppState.sidebar-visible : Rectangle {
                width: 260px; background: #181825;
                Sidebar { width: 100%; height: 100%; }
            }

            VerticalLayout {
                EditorPanel {
                    width: 100%;
                    has-connection: AppState.active-connection != "";
                    editor-content <=> AppState.current-sql;
                    execute-query(sql) => { AppState.execute-query(sql); }
                }

                // Results always at bottom — expands when data arrives
                ResultsPanel {
                    width: 100%;
                    height: AppState.results-visible ? 200px : 28px;
                    has-data: AppState.results-visible;
                    columns: AppState.result-columns;
                    rows: AppState.result-rows;
                    status: AppState.status-text;
                    output-text: AppState.result-text;
                }
            }
        }

        StatusBar { height: 24px; width: 100%; }
    }

    if AppState.command-palette-open : CommandPalette {
        x: (root.width - 560px) / 2;
        y: (root.height - 400px) / 2;
        width: 560px; height: 400px;
    }

}
