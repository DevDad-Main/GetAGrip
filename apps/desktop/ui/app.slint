import { StatusBar, Sidebar, EditorPanel, ResultsPanel, CommandPalette, ConnectDialog, TreeItem, CommandItem, TabData } from "components.slint";

export global AppState {
    in-out property <bool> sidebar-visible: false;
    in-out property <bool> results-visible: false;
    in-out property <bool> command-palette-open: false;
    in-out property <bool> connect-dialog-open: false;
    in-out property <string> active-connection: "";
    in-out property <string> connection-status: "● Disconnected";
    in-out property <string> status-text: "Ready";
    callback open-command-palette();
    callback close-command-palette();
    callback new-query();
    callback connect();
    callback disconnect();
    callback toggle-sidebar();
    callback toggle-results();
    callback execute-command(string);
    callback execute-query(string);
    callback select-sidebar-item(int);
    callback submit-connection(string, string, string, string, string, string, string, bool);
    in-out property <string> current-sql: "SELECT @@VERSION";
    in-out property <string> result-text: "";
    in-out property <[TreeItem]> sidebar-items;
    in-out property <[TabData]> editor-tabs;
    in-out property <int> active-tab-index: 0;
    callback new-tab();
}

export component MainWindow inherits Window {
    title: "GetAGrip";
    preferred-width: 1400px;
    preferred-height: 900px;
    min-width: 800px;
    min-height: 500px;
    background: #181724;

    // ---- Menu bar (absolutely positioned at top) ----
    menu := Rectangle {
        y: 0px; x: 0px; width: root.width; height: 32px; background: #11101a;
        HorizontalLayout {
            padding-left: 8px; padding-right: 8px;
            Text { text: "GetAGrip"; font-weight: 700; font-size: 13px; color: #e6e6eb; vertical-alignment: center; }
            Rectangle { width: 16px; }
            Rectangle { HorizontalLayout { padding-left: 4px; padding-right: 4px; padding-top: 8px; padding-bottom: 8px; Text { text: "File"; font-size: 12px; color: #e6e6eb; vertical-alignment: center; } } TouchArea { clicked => { AppState.connect-dialog-open = true; } } }
            Rectangle { HorizontalLayout { padding-left: 4px; padding-right: 4px; padding-top: 8px; padding-bottom: 8px; Text { text: "Edit"; font-size: 12px; color: #e6e6eb; vertical-alignment: center; } } TouchArea { clicked => { } } }
            Rectangle { HorizontalLayout { padding-left: 4px; padding-right: 4px; padding-top: 8px; padding-bottom: 8px; Text { text: "View"; font-size: 12px; color: #e6e6eb; vertical-alignment: center; } } TouchArea { clicked => { AppState.toggle-sidebar(); } } }
            Rectangle { width: 16px; }
            Rectangle { border-radius: 3px; background: #11101a; HorizontalLayout { padding-left: 8px; padding-right: 8px; padding-top: 6px; padding-bottom: 6px; Text { text: AppState.active-connection == "" ? "● Not Connected" : "● " + AppState.active-connection; font-size: 12px; vertical-alignment: center; color: AppState.active-connection == "" ? #6e6e7d : #a5d6a7; } } TouchArea { clicked => { AppState.connect-dialog-open = true; } } }
            Rectangle { border-radius: 3px; background: AppState.active-connection == "" ? #38364a : #a5d6a7; HorizontalLayout { padding-left: 8px; padding-right: 8px; padding-top: 4px; padding-bottom: 4px; spacing: 3px; if AppState.active-connection == "" : Image { source: @image-url("icons/play-off.svg"); width: 10px; height: 10px; } if AppState.active-connection != "" : Image { source: @image-url("icons/play.svg"); width: 10px; height: 10px; } Text { text: "Run"; font-size: 11px; font-weight: 600; color: AppState.active-connection == "" ? #6e6e7d : #181724; vertical-alignment: center; } } TouchArea { clicked => { if AppState.active-connection != "" { AppState.execute-query(AppState.current-sql); } } } }
            Rectangle { width: 4px; }
            Rectangle { border-radius: 3px; background: #11101a; HorizontalLayout { padding-left: 8px; padding-right: 8px; padding-top: 6px; padding-bottom: 6px; Text { text: "Ctrl+P"; font-size: 11px; color: #6e6e7d; vertical-alignment: center; } } TouchArea { clicked => { AppState.open-command-palette(); } } }
            Rectangle { border-radius: 3px; background: #11101a; HorizontalLayout { padding-left: 4px; padding-right: 4px; padding-top: 8px; padding-bottom: 8px; Text { text: "☰"; font-size: 14px; color: #e6e6eb; vertical-alignment: center; } } TouchArea { clicked => { AppState.toggle-sidebar(); } } }
        }
    }

    // ---- Status bar (absolutely positioned at bottom) ----
    StatusBar {
        y: root.height - 24px; x: 0px; width: root.width; height: 24px;
        left-text: AppState.connection-status;
        center-text: AppState.status-text;
    }

    // ---- Main content area (HorizontalLayout fills between menu and status) ----
    HorizontalLayout {
        y: 32px;
        width: root.width;
        height: root.height - 32px - 24px;

        // Sidebar (left)
        sidebar := Rectangle {
            width: AppState.sidebar-visible ? 260px : 0px;
            height: 100%;
            clip: true;
            Sidebar { width: 260px; height: 100%; items: AppState.sidebar-items; item-selected(idx) => { AppState.select-sidebar-item(idx); } }
        }

        // Center column — editor + results, proportional 60/40 split
        VerticalLayout {
            padding: 6px;

            // Editor bubble — 60% height when results visible, full height when not
            Rectangle {
                border-radius: 6px;
                border-width: 1px;
                border-color: #38364a;
                background: #282a36;
                height: AppState.results-visible ? 60% : 100%;
                EditorPanel {
                    width: 100%; height: 100%;
                    has-connection: AppState.active-connection != "";
                    editor-content <=> AppState.current-sql;
                    tabs: AppState.editor-tabs;
                    active-tab: AppState.active-tab-index;
                    execute-query(sql) => { AppState.execute-query(sql); }
                    tab-selected(idx) => { AppState.active-tab-index = idx; }
                    new-tab => { AppState.new-tab(); }
                }
            }

            // Results bubble — 40% height when visible
            if AppState.results-visible : Rectangle {
                border-radius: 6px;
                border-width: 1px;
                border-color: #38364a;
                background: #181724;
                height: 40%;
                ResultsPanel {
                    width: 100%; height: 100%;
                    has-data: true;
                    status: AppState.status-text;
                    output-text: AppState.result-text;
                }
            }
        }
    }

    // Overlays
    // Backdrop to dismiss command palette on click-outside
    if AppState.command-palette-open : TouchArea {
        x: 0px; y: 0px; width: root.width; height: root.height;
        clicked => { AppState.close-command-palette(); }
    }

    if AppState.command-palette-open : CommandPalette {
        x: (root.width - 480px) / 2; y: (root.height - 320px) / 2;
        width: 480px; height: 320px;
        commands: [
            { id: "connect", label: "Connect to Database", icon: "🔌", shortcut: "Ctrl+Shift+C" },
            { id: "disconnect", label: "Disconnect", icon: "✕", shortcut: "" },
            { id: "execute", label: "Execute Query", icon: "▶", shortcut: "Ctrl+Enter" },
            { id: "toggle-sidebar", label: "Toggle Explorer", icon: "☰", shortcut: "Ctrl+B" },
            { id: "toggle-results", label: "Toggle Results", icon: "📊", shortcut: "Ctrl+Shift+R" },
            { id: "new-query", label: "New Query Tab", icon: "+", shortcut: "Ctrl+N" },
        ];
        select-command(id) => { AppState.execute-command(id); }
    }

    if AppState.connect-dialog-open : ConnectDialog {
        x: (root.width - 460px) / 2; y: (root.height - 460px) / 2;
        width: 460px; height: 460px;
        connect(url, name, host, port, user, pass, db, trust) => {
            AppState.submit-connection(url, name, host, port, user, pass, db, trust);
            AppState.connect-dialog-open = false;
        }
        cancel => { AppState.connect-dialog-open = false; }
    }
}
