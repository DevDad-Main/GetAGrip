import { TextEdit } from "std-widgets.slint";

export struct TreeItem {
    label: string,
    kind: string,
    depth: int,
    expanded: bool,
    has-children: bool,
    icon: string,
}

export component Sidebar {
    in-out property <[TreeItem]> items;
    in-out property <int> selected-index: -1;
    callback item-selected(int);

    VerticalLayout {
        Rectangle {
            height: 28px;
            background: #181825;
            HorizontalLayout {
                padding-left: 8px; padding-right: 8px; padding-top: 4px; padding-bottom: 4px;
                Text {
                    text: "EXPLORER";
                    font-size: 10px; font-weight: 600; letter-spacing: 1px; color: #6c7086;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            clip: true;
            Flickable {
                viewport-y: 0px;
                VerticalLayout {
                    for item[idx] in root.items : Rectangle {
                        height: 26px;
                        background: idx == root.selected-index ? #45475a : #00000000;

                        HorizontalLayout {
                            padding-left: 8px + item.depth * 16px;
                            spacing: 0px;

                            Rectangle {
                                width: 16px; height: 100%;
                                if item.has-children : Image {
                                    source: item.expanded ? @image-url("icons/chevron-down.svg") : @image-url("icons/chevron-right.svg");
                                    width: 12px; height: 12px;
                                    x: 2px;
                                    y: (parent.height - 12px) / 2;
                                }
                            }

                            Rectangle { width: 4px; }

                            Rectangle {
                                width: 16px; height: 100%;
                                if item.kind == "server" : Image {
                                    source: @image-url("icons/server.svg");
                                    width: 16px; height: 16px;
                                    y: (parent.height - 16px) / 2;
                                }
                                if item.kind == "database" : Image {
                                    source: @image-url("icons/database.svg");
                                    width: 16px; height: 16px;
                                    y: (parent.height - 16px) / 2;
                                }
                                if item.kind == "folder" : Image {
                                    source: @image-url("icons/folder.svg");
                                    width: 16px; height: 16px;
                                    y: (parent.height - 16px) / 2;
                                }
                                if item.kind == "table" : Image {
                                    source: @image-url("icons/table.svg");
                                    width: 16px; height: 16px;
                                    y: (parent.height - 16px) / 2;
                                }
                                if item.kind == "view" : Image {
                                    source: @image-url("icons/view.svg");
                                    width: 16px; height: 16px;
                                    y: (parent.height - 16px) / 2;
                                }
                                if item.kind == "function" : Image {
                                    source: @image-url("icons/function.svg");
                                    width: 16px; height: 16px;
                                    y: (parent.height - 16px) / 2;
                                }
                                if item.kind == "column" : Image {
                                    source: @image-url("icons/column.svg");
                                    width: 14px; height: 14px;
                                    y: (parent.height - 14px) / 2;
                                }
                            }

                            Rectangle { width: 6px; }

                            Text {
                                text: item.label;
                                font-size: 12px; vertical-alignment: center;
                                color: item.kind == "server" ? #cdd6f4 :
                                       item.kind == "database" ? #a6e3a1 :
                                       item.kind == "table" ? #cdd6f4 :
                                       item.kind == "function" ? #89b4fa :
                                       item.kind == "view" ? #cba6f7 :
                                       #6c7086;
                                overflow: elide;
                            }
                        }

                        TouchArea { clicked => { root.item-selected(idx); } }
                    }
                }
            }
        }
    }
}

export struct TabData {
    title: string,
    is-query: bool,
    modified: bool,
}

export component EditorPanel {
    in-out property <[TabData]> tabs;
    in-out property <int> active-tab: 0;
    in-out property <string> editor-content: "SELECT @@VERSION";
    in-out property <string> cursor-position: "1:1";
    in-out property <bool> editor-modified: false;
    in-out property <bool> has-connection: false;
    callback tab-selected(int);
    callback tab-closed(int);
    callback new-tab();
    callback editor-changed(string);
    callback execute-query(string);

    VerticalLayout {
        // Tab bar
        if root.tabs.length > 0 : Rectangle {
            height: 28px;
            background: #181724;
            HorizontalLayout {
                spacing: 0;
                for tab[idx] in root.tabs : Rectangle {
                    width: 150px;
                    height: 100%;
                    background: idx == root.active-tab ? #282a36 : #181724;

                    if idx == root.active-tab : Rectangle {
                        y: parent.height - 2px;
                        height: 2px; x: 0px; width: parent.width;
                        background: #a5d6a7;
                    }

                    TouchArea {
                        clicked => { root.tab-selected(idx); }
                        HorizontalLayout {
                            padding-left: 8px; padding-right: 4px; spacing: 4px;
                            Text {
                                text: tab.title;
                                font-size: 12px; vertical-alignment: center;
                                color: idx == root.active-tab ? #e6e6eb : #8a8a93;
                                overflow: elide; horizontal-alignment: left;
                            }
                            if tab.modified : Text {
                                text: "●"; font-size: 8px; color: #f9e2af; vertical-alignment: center;
                            }
                            Rectangle { horizontal-stretch: 1; }
                            TouchArea {
                                clicked => { root.tab-closed(idx); }
                                Rectangle { width: 16px; height: 16px;
                                    Text { text: "x"; font-size: 13px; color: #8a8a93; horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                        }
                    }
                }
                Rectangle { }
                TouchArea { clicked => { root.new-tab(); }
                    Rectangle { width: 24px; height: 24px;
                        Text { text: "+"; font-size: 16px; color: #8a8a93; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }

        // Editor area
        Rectangle {
            background: #282a36;
            VerticalLayout {
                padding-left: 8px; padding-top: 4px; padding-right: 8px; padding-bottom: 4px;
                TextEdit {
                    text <=> root.editor-content;
                    font-size: 14px;
                    font-family: "monospace";
                    edited(str) => {
                        root.editor-content = str;
                        root.editor-changed(str);
                    }
                }
            }
        }
    }
}

export struct ResultRowData {
    c0: string, c1: string, c2: string, c3: string, c4: string, c5: string,
}

export component ResultsPanel {
    in-out property <[string]> columns;
    in-out property <[ResultRowData]> rows;
    in-out property <string> status: "";
    in-out property <int> selected-row: -1;
    in-out property <bool> has-data: false;
    in-out property <string> output-text: "";
    callback row-selected(int);
    callback close-results();

    VerticalLayout {
        // Header row
        Rectangle {
            height: 24px;
            HorizontalLayout {
                padding-left: 12px; padding-right: 8px;
                Text { text: "RESULTS"; font-size: 10px; font-weight: 600; color: #6e6e7d; vertical-alignment: center; }
                Text { text: root.status; font-size: 10px; color: #6e6e7d; vertical-alignment: center; }
                Rectangle { horizontal-stretch: 1; }
                Text { text: "×"; font-size: 14px; color: #6e6e7d; vertical-alignment: center; }
                TouchArea { clicked => { root.close-results(); } }
            }
        }

        // Divider
        Rectangle { height: 1px; background: #38364a; }

        // Output
        if root.has-data : Rectangle {
            clip: true;
            VerticalLayout {
                padding-left: 12px; padding-right: 12px; padding-top: 8px; padding-bottom: 8px;
                Text {
                    text: root.output-text;
                    font-size: 13px;
                    font-family: "monospace";
                    color: #6e6e7d;
                    vertical-alignment: top;
                    horizontal-alignment: left;
                    wrap: word-wrap;
                }
            }
        }
    }
}

export component StatusBar {
    in-out property <string> left-text: "● Disconnected";
    in-out property <string> center-text: "Ready";
    in-out property <string> right-text: "Ln 1, Col 1";

    Rectangle {
        background: #11111b;
        HorizontalLayout {
            padding-left: 10px; padding-right: 10px; spacing: 12px;
            Text { text: root.left-text; font-size: 11px; color: #a6e3a1; vertical-alignment: center; }
            Rectangle { width: 1px; background: #45475a; }
            Text { text: root.center-text; font-size: 11px; color: #6c7086; vertical-alignment: center; }
            Rectangle { }
            Text { text: root.right-text; font-size: 11px; color: #6c7086; vertical-alignment: center; }
        }
    }
}

export struct CommandItem {
    id: string, label: string, icon: string, shortcut: string,
}
export component CommandPalette {
    in-out property <string> search-text;
    in-out property <[CommandItem]> commands;
    in-out property <int> selected: 0;
    callback select-command(string);
    callback dismissed();

    Rectangle {
        border-radius: 8px; background: #181825; border-width: 1px; border-color: #45475a;
        drop-shadow-blur: 16px; drop-shadow-color: #00000088;
        VerticalLayout {
            Rectangle {
                height: 40px; background: #1e1e2e;
                HorizontalLayout {
                    padding-left: 12px; padding-right: 12px; padding-top: 6px; padding-bottom: 6px; spacing: 8px;
                    Text { text: "⌘"; font-size: 14px; color: #6c7086; vertical-alignment: center; }
                    TextInput {
                        text <=> root.search-text;
                        font-size: 14px;
                        color: #cdd6f4;
                    }
                }
            }
            Rectangle { height: 1px; background: #45475a; }
            VerticalLayout {
                for cmd[idx] in root.commands : Rectangle {
                    height: 32px;
                    background: idx == root.selected ? #45475a : #00000000;
                    HorizontalLayout {
                        padding-left: 14px; padding-right: 14px; spacing: 8px;
                        Text { text: cmd.icon; font-size: 14px; vertical-alignment: center; }
                        Text { text: cmd.label; font-size: 13px; color: #cdd6f4; vertical-alignment: center; }
                        Rectangle { }
                        if cmd.shortcut != "" : Text { text: cmd.shortcut; font-size: 11px; color: #6c7086; vertical-alignment: center; }
                    }
                    TouchArea { clicked => { root.select-command(cmd.id); } }
                }
            }
        }
    }
}

export component ConnectDialog {
    in-out property <string> conn-url: "";
    callback connect(string, string, string, string, string, string, string, bool);
    callback cancel();

    property <string> name: "My SQL Server";
    property <string> host: "localhost";
    property <string> port: "1433";
    property <string> username: "sa";
    property <string> password: "";
    property <string> database: "";
    property <bool> trust-cert: true;

    Rectangle {
        border-radius: 8px; background: #181825; border-width: 1px; border-color: #45475a;
        drop-shadow-blur: 20px; drop-shadow-color: #000000aa;
        width: 460px; height: 460px;

        VerticalLayout {
            Rectangle {
                height: 36px; background: #11111b;
                HorizontalLayout {
                    padding-left: 14px; padding-right: 14px; padding-top: 6px; padding-bottom: 6px;
                    Text { text: "Connect to Database"; font-size: 13px; font-weight: 600; color: #cdd6f4; vertical-alignment: center; }
                }
            }

            VerticalLayout {
                padding-left: 14px; padding-right: 14px; padding-top: 10px; padding-bottom: 10px;
                spacing: 8px;

                // Connection URL
                Text { text: "Connection URL"; font-size: 10px; color: #6c7086; }
                Rectangle { background: #1e1e2e; height: 28px; border-radius: 3px;
                    TextInput { text <=> root.conn-url; font-size: 12px; color: #cdd6f4; font-family: "monospace"; }
                }

                Rectangle { height: 1px; background: #45475a; }

                Text { text: "Connection Name"; font-size: 10px; color: #6c7086; }
                Rectangle { background: #1e1e2e; height: 28px; border-radius: 3px;
                    TextInput { text <=> root.name; font-size: 13px; color: #cdd6f4; }
                }

                HorizontalLayout {
                    spacing: 10px;
                    VerticalLayout {
                        Text { text: "Host"; font-size: 10px; color: #6c7086; }
                        Rectangle { background: #1e1e2e; height: 28px; border-radius: 3px;
                            TextInput { text <=> root.host; font-size: 13px; color: #cdd6f4; }
                        }
                    }
                    VerticalLayout {
                        Text { text: "Port"; font-size: 10px; color: #6c7086; }
                        Rectangle { background: #1e1e2e; height: 28px; border-radius: 3px;
                            TextInput { text <=> root.port; font-size: 13px; color: #cdd6f4; }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 10px;
                    VerticalLayout {
                        Text { text: "Username"; font-size: 10px; color: #6c7086; }
                        Rectangle { background: #1e1e2e; height: 28px; border-radius: 3px;
                            TextInput { text <=> root.username; font-size: 13px; color: #cdd6f4; }
                        }
                    }
                    VerticalLayout {
                        Text { text: "Password"; font-size: 10px; color: #6c7086; }
                        Rectangle { background: #1e1e2e; height: 28px; border-radius: 3px;
                            TextInput { text <=> root.password; font-size: 13px; color: #cdd6f4; }
                        }
                    }
                }

                Text { text: "Database (optional)"; font-size: 10px; color: #6c7086; }
                Rectangle { background: #1e1e2e; height: 28px; border-radius: 3px;
                    TextInput { text <=> root.database; font-size: 13px; color: #cdd6f4; }
                }

                HorizontalLayout {
                    spacing: 6px;
                    Rectangle {
                        width: 14px; height: 14px; border-width: 1px; border-color: #45475a;
                        background: root.trust-cert ? #a6e3a1 : #1e1e2e;
                        Text { text: root.trust-cert ? "✓" : ""; font-size: 10px; color: #1e1e2e; horizontal-alignment: center; }
                        TouchArea { clicked => { root.trust-cert = !root.trust-cert; } }
                    }
                    Text { text: "Trust server certificate"; font-size: 11px; color: #6c7086; vertical-alignment: center; }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        horizontal-stretch: 1;
                        Rectangle {
                            border-radius: 4px; background: #a6e3a1; height: 30px;
                            Text { text: "Connect"; font-size: 13px; font-weight: 600; color: #1e1e2e; vertical-alignment: center; horizontal-alignment: center; }
                            TouchArea { clicked => { root.connect(root.conn-url, root.name, root.host, root.port, root.username, root.password, root.database, root.trust-cert); } }
                        }
                    }
                    Rectangle {
                        border-radius: 4px; background: #45475a; height: 30px;
                        HorizontalLayout {
                            padding-left: 14px; padding-right: 14px;
                            Text { text: "Cancel"; font-size: 13px; color: #cdd6f4; vertical-alignment: center; }
                        }
                        TouchArea { clicked => { root.cancel(); } }
                    }
                }
            }
        }
    }
}
