export struct TreeItem {
    label: string,
    kind: string,
    depth: int,
    expanded: bool,
    has-children: bool,
    icon: string,
}

export component Sidebar {
    in-out property <[TreeItem]> items;
    in-out property <int> selected-index: -1;
    callback item-selected(int);

    VerticalLayout {
        Rectangle {
            height: 28px;
            background: #181825;
            HorizontalLayout {
                padding-left: 8px; padding-right: 8px; padding-top: 4px; padding-bottom: 4px;
                Text {
                    text: "EXPLORER";
                    font-size: 10px; font-weight: 600; letter-spacing: 1px; color: #6c7086;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            clip: true;
            VerticalLayout {
                for item[idx] in root.items : Rectangle {
                    height: 26px;
                    background: idx == root.selected-index ? #45475a : #00000000;

                    HorizontalLayout {
                        padding-left: 16px + item.depth * 16px;
                        padding-right: 8px;
                        spacing: 6px;

                        if item.kind == "folder" : Text {
                            text: item.expanded ? "▾" : "▸";
                            font-size: 11px; color: #6c7086; vertical-alignment: center;
                        }
                        if item.kind == "server" : Text {
                            text: "🖥"; font-size: 13px; vertical-alignment: center;
                        }
                        if item.kind == "database" : Text {
                            text: "🗄"; font-size: 13px; vertical-alignment: center;
                        }
                        if item.kind == "schema" : Text {
                            text: "📁"; font-size: 13px; vertical-alignment: center;
                        }
                        if item.kind == "table" : Text {
                            text: "📋"; font-size: 13px; vertical-alignment: center;
                        }
                        if item.kind == "view" : Text {
                            text: "👁"; font-size: 13px; vertical-alignment: center;
                        }
                        if item.kind == "function" : Text {
                            text: "ƒ"; font-size: 12px; color: #89b4fa; vertical-alignment: center;
                        }

                        Text {
                            text: item.label;
                            font-size: 12px; vertical-alignment: center;
                            color: item.kind == "function" ? #89b4fa :
                                   item.kind == "table" ? #cdd6f4 : #6c7086;
                            overflow: elide;
                        }
                    }

                    TouchArea { clicked => { root.item-selected(idx); } }
                }
            }
        }
    }
}

export struct TabData {
    title: string,
    is-query: bool,
    modified: bool,
}

export component EditorPanel {
    in-out property <[TabData]> tabs;
    in-out property <int> active-tab: 0;
    in-out property <string> editor-content: "/* GetAGrip SQL Editor */\n\nSELECT 1;";
    in-out property <string> cursor-position: "1:1";
    in-out property <bool> editor-modified: false;
    in-out property <bool> has-connection: false;
    callback tab-selected(int);
    callback tab-closed(int);
    callback new-tab();
    callback editor-changed(string);
    callback execute-query(string);

    VerticalLayout {
        Rectangle {
            height: 32px; background: #181825;
            HorizontalLayout {
                spacing: 0;
                for tab[idx] in root.tabs : Rectangle {
                    width: 160px; height: 100%;
                    background: idx == root.active-tab ? #1e1e2e : #181825;

                    HorizontalLayout {
                        padding-left: 8px; padding-right: 8px; spacing: 4px;
                        if tab.is-query : Text {
                            text: "▶"; font-size: 10px; color: #cba6f7; vertical-alignment: center;
                        }
                        Text {
                            text: tab.title; font-size: 12px; vertical-alignment: center;
                            color: idx == root.active-tab ? #cdd6f4 : #6c7086;
                            overflow: elide; horizontal-alignment: left;
                        }
                        if tab.modified : Text {
                            text: "●"; font-size: 8px; color: #fab387; vertical-alignment: center;
                        }
                        Text { text: "×"; font-size: 13px; color: #6c7086; vertical-alignment: center; }
                    }
                    TouchArea { clicked => { root.tab-selected(idx); } }
                }
                Rectangle { }
                TouchArea {
                    clicked => { root.new-tab(); }
                    Rectangle {
                        width: 28px; height: 28px; border-radius: 4px;
                        Text { text: "+"; font-size: 16px; color: #6c7086; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: #1e1e2e;
            padding: 8px;
            Text {
                text: root.editor-content;
                font-size: 14px;
                font-family: "monospace";
                color: #cdd6f4;
                horizontal-alignment: left;
                vertical-alignment: top;
            }
        }

        Rectangle {
            height: 28px; background: #181825;
            HorizontalLayout {
                padding-left: 8px; padding-right: 8px; padding-top: 4px; padding-bottom: 4px; spacing: 12px;
                Text { text: root.cursor-position; font-size: 11px; color: #6c7086; vertical-alignment: center; }
                Rectangle { }
                Rectangle {
                    border-radius: 4px;
                    background: root.has-connection ? #cba6f7 : #45475a;
                    height: 22px;
                    HorizontalLayout {
                        padding-left: 14px; padding-right: 14px; padding-top: 2px; padding-bottom: 2px;
                        Text {
                            text: "▶ Run";
                            font-size: 11px; font-weight: 600;
                            color: root.has-connection ? #1e1e2e : #6c7086;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea {
                        clicked => {
                            if root.has-connection {
                                root.execute-query(root.editor-content);
                            }
                        }
                    }
                }
            }
        }
    }
}

export struct ResultRowData {
    c0: string, c1: string, c2: string, c3: string, c4: string, c5: string,
}

export component ResultsPanel {
    in-out property <[string]> columns;
    in-out property <[ResultRowData]> rows;
    in-out property <string> status: "0 rows — 0ms";
    in-out property <int> selected-row: -1;
    in-out property <bool> has-data: false;
    in-out property <string> output-text: "";
    callback row-selected(int);
    callback close-results();

    VerticalLayout {
        Rectangle {
            height: 28px; background: #181825;
            HorizontalLayout {
                padding-left: 8px; padding-right: 8px; padding-top: 4px; padding-bottom: 4px; spacing: 8px;
                Text { text: "RESULTS"; font-size: 10px; font-weight: 600; letter-spacing: 1px; color: #6c7086; vertical-alignment: center; }
                Text { text: root.status; font-size: 11px; color: #6c7086; vertical-alignment: center; }
                Rectangle { }
                Text { text: "×"; font-size: 14px; color: #6c7086; vertical-alignment: center; }
                TouchArea { clicked => { root.close-results(); } }
            }
        }
        if root.has-data : Rectangle {
            clip: true;
            Text {
                text: root.output-text;
                font-size: 13px;
                font-family: "monospace";
                color: #cdd6f4;
                vertical-alignment: top;
            }
        }
    }
}

export component StatusBar {
    in-out property <string> left-text: "● Disconnected";
    in-out property <string> center-text: "Ready";
    in-out property <string> right-text: "Ln 1, Col 1";

    Rectangle {
        background: #11111b;
        HorizontalLayout {
            padding-left: 10px; padding-right: 10px; spacing: 12px;
            Text { text: root.left-text; font-size: 11px; color: #a6e3a1; vertical-alignment: center; }
            Rectangle { width: 1px; background: #45475a; }
            Text { text: root.center-text; font-size: 11px; color: #6c7086; vertical-alignment: center; }
            Rectangle { }
            Text { text: root.right-text; font-size: 11px; color: #6c7086; vertical-alignment: center; }
        }
    }
}

export struct CommandItem {
    id: string, label: string, icon: string, shortcut: string,
}

export component CommandPalette {
    in-out property <string> search-text;
    in-out property <[CommandItem]> commands;
    in-out property <int> selected: 0;
    callback select-command(string);
    callback dismissed();

    Rectangle {
        border-radius: 8px; background: #181825; border-width: 1px; border-color: #45475a;
        drop-shadow-blur: 16px; drop-shadow-color: #00000088;
        VerticalLayout {
            Rectangle {
                height: 40px;
                HorizontalLayout {
                    padding-left: 14px; padding-right: 14px; padding-top: 8px; padding-bottom: 8px; spacing: 8px;
                    Text { text: "⌘"; font-size: 14px; color: #6c7086; vertical-alignment: center; }
                    TextInput { text <=> root.search-text; font-size: 14px; color: #cdd6f4; }
                }
            }
            Rectangle { height: 1px; background: #45475a; }
            VerticalLayout {
                for cmd[idx] in root.commands : Rectangle {
                    height: 32px;
                    background: idx == root.selected ? #45475a : #00000000;
                    HorizontalLayout {
                        padding-left: 14px; padding-right: 14px; spacing: 8px;
                        Text { text: cmd.icon; font-size: 14px; vertical-alignment: center; }
                        Text { text: cmd.label; font-size: 13px; color: #cdd6f4; vertical-alignment: center; }
                        Rectangle { }
                        if cmd.shortcut != "" : Text { text: cmd.shortcut; font-size: 11px; color: #6c7086; vertical-alignment: center; }
                    }
                    TouchArea { clicked => { root.select-command(cmd.id); } }
                }
            }
        }
        backdrop := TouchArea {
            x: -500px; y: -500px; width: 2000px; height: 2000px;
            clicked => { root.dismissed(); }
        }
    }
}
